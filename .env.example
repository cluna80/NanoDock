# ===========================================
# NanoDock — Environment Configuration
# Copy this file to `.env` and fill in your values.
# NEVER commit `.env` to git.
# ===========================================

# ---- Arc Testnet ----
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=5042002
ARC_EXPLORER=https://testnet.arcscan.app

# USDC contract on Arc testnet (native gas token; find current address in Circle docs)
# https://docs.circle.com/arc
USDC_ADDRESS=

# ---- Agent Wallets ----
# Generate these with `npm run wallets:new` — don't reuse mainnet keys.
# Each agent runs as its own onchain identity so it can receive payments.

# User/Buyer wallet (the one funding docking requests)
BUYER_PRIVATE_KEY=

# Orchestrator agent — receives the top-level payment, pays downstream agents
ORCHESTRATOR_PRIVATE_KEY=
ORCHESTRATOR_ADDRESS=

# Docking agent — performs AutoDock Vina compute
DOCKING_AGENT_PRIVATE_KEY=
DOCKING_AGENT_ADDRESS=

# ADMET agent — returns property predictions
ADMET_AGENT_PRIVATE_KEY=
ADMET_AGENT_ADDRESS=

# Validator agent — ChEMBL/PubChem novelty check
VALIDATOR_AGENT_PRIVATE_KEY=
VALIDATOR_AGENT_ADDRESS=

# ---- x402 / Nanopayments ----
# Circle's x402 facilitator endpoint (check current URL in Circle docs)
X402_FACILITATOR_URL=https://api.circle.com/v1/w3s/x402/facilitator

# Per-action pricing (USDC, decimal string). Must be ≤ $0.01 to meet hackathon criteria.
PRICE_PER_DOCK_USDC=0.005
PRICE_PER_ADMET_USDC=0.002
PRICE_PER_VALIDATE_USDC=0.001

# ---- Server ----
PORT=3402
SERVER_PUBLIC_URL=http://localhost:3402

# ---- Drug Discovery Backend ----
# Path to your existing drug_discovery.py / autonomous_drug_agent.py
# On BossKing this will be something like /mnt/c/Users/.../drug_discovery
DRUG_DISCOVERY_PATH=../drug_discovery
PYTHON_BIN=python3

# ---- ERC-8004 Trustless Agents ----
# Populate these AFTER running `npm run register` (which mints the NFTs).
# If empty, the reputation feedback loop is silently disabled — everything else still works.
ORCHESTRATOR_AGENT_ID=
DOCKING_AGENT_AGENT_ID=
ADMET_AGENT_AGENT_ID=
VALIDATOR_AGENT_AGENT_ID=

# ---- Gemini (optional, for orchestration layer) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash
